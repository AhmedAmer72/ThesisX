# SoSoValue — https://sosovalue-1.gitbook.io/sosovalue-api-doc

SOSOVALUE_API_KEY=

SOSOVALUE_BASE_URL=https://openapi.sosovalue.com



# OpenAI — optional enhancement; SoSo deterministic committee is the default path

OPENAI_API_KEY=

OPENAI_MODEL=gpt-4o-mini

OPENAI_REQUIRED=false



# Database — PostgreSQL (Neon for Vercel; docker-compose for local)

DATABASE_URL=postgresql://thesisx:thesisx@localhost:5432/thesisx



# Redis / Upstash (optional — in-memory fallback when unset)

REDIS_URL=

REDIS_TOKEN=



# Production profile

PRODUCTION_MODE=false

BUILDATHON_MODE=false

DEMO_MODE=false

EXECUTION_MODE=testnet



# SoDEX testnet

SODEX_SPOT_BASE=https://testnet-gw.sodex.dev/api/v1/spot

SODEX_PERPS_BASE=https://testnet-gw.sodex.dev/api/v1/perps

SODEX_CHAIN_ID=138565

SODEX_API_KEY_NAME=

SODEX_API_PRIVATE_KEY=

SODEX_ACCOUNT_ID=

SODEX_USER_ADDRESS=

ALLOW_MAINNET=false



# Auth & admin

WALLET_SESSION_SECRET=

ADMIN_WALLET_ADDRESSES=

CRON_SECRET=



# Billing / analytics

STRIPE_SECRET_KEY=

STRIPE_WEBHOOK_SECRET=

NEXT_PUBLIC_POSTHOG_KEY=

SENTRY_DSN=



# Seed & marketplace

SEED_DEMO_FUNDS=false

SHOW_SEEDED_FUNDS=false



# Wallet

NEXT_PUBLIC_ALLOW_MAINNET=false

NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

NEXT_PUBLIC_APP_URL=http://localhost:3000



ADMIN_KILL_SWITCH=false

