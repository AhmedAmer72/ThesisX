{
  "buildCommand": "npx prisma generate && npx prisma db push --accept-data-loss && next build",
  "framework": "nextjs",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/tick",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/rebalance/run",
      "schedule": "0 12 * * *"
    }
  ]
}
